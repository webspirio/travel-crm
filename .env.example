# AnyTour CRM — local development environment.
# Copy this to .env.local and fill in the keys from `supabase status --output env`
# after `npm run db:start`.

VITE_SUPABASE_URL=http://localhost:54321

# Anon key from `supabase status`. Local dev keys are stable across `supabase init`s
# (derived from a local JWT secret), but each developer should still copy from their
# own `supabase status` output to be safe.
VITE_SUPABASE_ANON_KEY=

# Service-role key (server-only). Used by scripts/provision-tenant.ts via
# `tsx --env-file=.env.local`. Never expose to the browser.
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=
